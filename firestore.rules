rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /profiles/{docId} {
      allow read, write: if true;
    }

    match /meals/{docId} {
      allow read, write: if true;
    }

    match /weights/{docId} {
      allow read, write: if true;
    }

    match /workouts/{docId} {
      allow read, write: if true;
    }

    match /settings/{docId} {
      allow read, write: if true;
    }

    match /recipes/{docId} {
      allow read, write: if true;
    }
  }
}